{
  "name": "art-gallery-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "prepare": "husky || true",
    "lint-staged": "lint-staged",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:lint": "npm run lint --workspace=frontend",
    "frontend:typecheck": "tsc --noEmit --project frontend/tsconfig.json"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "npm run frontend:lint -- --fix",
      "npx prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.9.4"
  }
}
